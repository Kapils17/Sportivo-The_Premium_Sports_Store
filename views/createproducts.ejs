<%- include('./partials/header') %>

    <% if(success.length>0){ %>
        <div class="fixed top-24 left-1/2 -translate-x-1/2 z-50 px-5 py-3 rounded-xl bg-accent/90 backdrop-blur-md shadow-lg shadow-accent/20 border border-blue-400/30">
            <span class="inline-block text-sm font-medium text-white">
                <%= success %>
            </span>
        </div>
        <% } %>

            <div class="min-h-screen flex flex-col">
                <div class="w-full flex flex-col lg:flex-row px-6 md:px-12 lg:px-20 py-16 gap-12 flex-grow">

                    <div class="w-full lg:w-1/5">
                        <p class="text-xs font-semibold uppercase tracking-widest text-white/40 mb-6">Dashboard</p>
                        <div class="flex flex-col gap-4">
                            <a class="text-sm font-medium text-white/70 hover:text-accent transition-colors duration-300 w-fit flex items-center gap-2" href="">
                                <i class="ri-grid-line"></i> All Products
                            </a>
                            <a class="text-sm font-medium text-white hover:text-accent transition-colors duration-300 w-fit flex items-center gap-2" href="">
                                <i class="ri-add-circle-line"></i> Create new product
                            </a>
                        </div>
                    </div>

                    <main class="w-full lg:w-4/5 bg-white/5 border border-white/10 backdrop-blur-xl rounded-2xl p-8 md:p-10">
                        <h2 class="font-display text-2xl font-black uppercase tracking-tight mb-8">Create New Product</h2>

                        <form autocomplete="off" action="/product/create" method="post" enctype="multipart/form-data">
                            <div class="mb-10">
                                <h3 class="text-xs font-semibold uppercase tracking-widest text-white/40 mb-4">Product Details</h3>
                                <div class="mb-5">
                                    <label class="block mb-2 text-sm font-medium text-white/70">Product Image</label>
                                    <input name="image" type="file" class="block w-full text-sm text-white/60 file:mr-4 file:py-2.5 file:px-5 file:rounded-lg file:border-0 file:text-xs file:font-bold file:uppercase file:tracking-widest file:bg-accent file:text-white hover:file:bg-blue-500 file:cursor-pointer file:transition-colors file:duration-300 bg-white/5 border border-white/10 rounded-lg py-1.5" value="Select File">
                                </div>
                                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                                    <input name="name" type="text" placeholder="Product Name"
                                        class="bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm placeholder-white/30 outline-none focus:border-accent transition-colors duration-300 w-full">
                                    <input name="price" type="text" placeholder="Product Price"
                                        class="bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm placeholder-white/30 outline-none focus:border-accent transition-colors duration-300 w-full">
                                    <input name="discount" type="text" placeholder="Discount Price"
                                        class="bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm placeholder-white/30 outline-none focus:border-accent transition-colors duration-300 w-full">
                                </div>
                            </div>

                            <div class="mb-8">
                                <h3 class="text-xs font-semibold uppercase tracking-widest text-white/40 mb-4">Panel Details</h3>
                                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                                    <input name="bgcolor" type="text" placeholder="Background Color"
                                        class="bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm placeholder-white/30 outline-none focus:border-lime transition-colors duration-300 w-full">
                                    <input name="panelcolor" type="text" placeholder="Panel Color"
                                        class="bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm placeholder-white/30 outline-none focus:border-lime transition-colors duration-300 w-full">
                                    <input name="textcolor" type="text" placeholder="Text Color"
                                        class="bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm placeholder-white/30 outline-none focus:border-lime transition-colors duration-300 w-full">
                                </div>
                            </div>
                            <input class="px-8 py-3.5 rounded-xl bg-accent text-white text-xs font-bold uppercase tracking-widest cursor-pointer hover:bg-blue-500 hover:shadow-[0_0_25px_rgba(37,99,235,0.5)] hover:scale-[1.02] active:scale-[0.98] transition-all duration-300"
                                type="submit" value="Create New Product">
                        </form>
                    </main>
                </div>
            </div>
            <%- include('./partials/footer') %>
