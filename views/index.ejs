<%- include('./partials/header') %>

    <% if(error.length>0){ %>
        <div class="fixed top-24 left-1/2 -translate-x-1/2 z-50 px-5 py-3 rounded-xl bg-red-500/90 backdrop-blur-md shadow-lg shadow-red-500/20 border border-red-400/30">
            <span class="inline-block text-sm font-medium text-white">
                <%= error %>
            </span>
        </div>
        <% } %>

            <div class="relative w-full min-h-screen overflow-hidden">

                <!-- Ambient glow -->
                <div class="pointer-events-none absolute -top-40 -left-40 w-[500px] h-[500px] bg-accent/20 rounded-full blur-[120px]"></div>
                <div class="pointer-events-none absolute -bottom-40 -right-40 w-[500px] h-[500px] bg-lime/10 rounded-full blur-[120px]"></div>

                <div class="relative w-full min-h-screen flex flex-col lg:flex-row items-stretch px-6 md:px-16 lg:px-20 py-10">

                    <!-- Register -->
                    <div class="w-full lg:w-1/2 flex items-center justify-center py-10">
                        <div class="w-full max-w-md bg-white/5 backdrop-blur-xl border border-white/10 rounded-3xl shadow-2xl p-8 md:p-10">

                            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-accent mb-3">Join the club</p>
                            <h3 class="font-display text-3xl md:text-4xl font-black uppercase tracking-tight leading-none">
                                welcome to <span class="text-accent">sportivo</span>
                            </h3>
                            <h4 class="text-white/50 mt-3 mb-8">create your account</h4>

                            <form autocomplete="off" action="/user/register" method="post" class="space-y-4">
                                <input
                                    class="bg-white/5 block w-full px-4 py-3 border border-white/10 rounded-xl text-sm placeholder-white/30 outline-none focus:border-accent focus:bg-white/10 transition-all duration-300"
                                    type="text" placeholder="Full Name" name="fullname">
                                <input
                                    class="bg-white/5 block w-full px-4 py-3 border border-white/10 rounded-xl text-sm placeholder-white/30 outline-none focus:border-accent focus:bg-white/10 transition-all duration-300"
                                    type="email" placeholder="Email" name="email">
                                <input
                                    class="bg-white/5 block w-full px-4 py-3 border border-white/10 rounded-xl text-sm placeholder-white/30 outline-none focus:border-accent focus:bg-white/10 transition-all duration-300"
                                    type="password" placeholder="Password" name="password">
                                <input
                                    class="w-full mt-2 px-5 py-3.5 rounded-xl bg-accent text-white text-xs font-bold uppercase tracking-widest cursor-pointer hover:bg-blue-500 hover:shadow-[0_0_25px_rgba(37,99,235,0.5)] hover:scale-[1.02] active:scale-[0.98] transition-all duration-300"
                                    type="submit" value="Create My Account">
                            </form>

                        </div>
                    </div>

                    <!-- Divider -->
                    <div class="hidden lg:flex items-center justify-center px-4">
                        <div class="w-[1px] h-2/3 bg-gradient-to-b from-transparent via-white/15 to-transparent"></div>
                    </div>

                    <!-- Login -->
                    <div class="w-full lg:w-1/2 flex items-center justify-center py-10">
                        <div class="w-full max-w-md bg-white/5 backdrop-blur-xl border border-white/10 rounded-3xl shadow-2xl p-8 md:p-10">

                            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-lime mb-3">Already a member</p>
                            <h4 class="font-display text-3xl md:text-4xl font-black uppercase tracking-tight leading-none mb-8">
                                login your account
                            </h4>

                            <form autocomplete="off" action="/user/login" method="post" class="space-y-4">
                                <input
                                    class="block bg-white/5 w-full px-4 py-3 border border-white/10 rounded-xl text-sm placeholder-white/30 outline-none focus:border-lime focus:bg-white/10 transition-all duration-300"
                                    type="email" placeholder="Email" name="email">
                                <input
                                    class="block bg-white/5 w-full px-4 py-3 border border-white/10 rounded-xl text-sm placeholder-white/30 outline-none focus:border-lime focus:bg-white/10 transition-all duration-300"
                                    type="password" placeholder="Password" name="password">
                                <input
                                    class="w-full block mt-2 px-5 py-3.5 rounded-xl bg-white text-noir text-xs font-bold uppercase tracking-widest cursor-pointer hover:bg-lime hover:shadow-[0_0_25px_rgba(132,204,22,0.4)] hover:scale-[1.02] active:scale-[0.98] transition-all duration-300"
                                    type="submit" value="Login">
                            </form>

                        </div>
                    </div>

                </div>
            </div>
            <%- include('./partials/footer') %>
