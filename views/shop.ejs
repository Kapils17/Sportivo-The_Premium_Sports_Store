<%- include('./partials/header') %>


<% if(success.length>0){ %>
        <div class="fixed top-24 left-1/2 -translate-x-1/2 z-50 px-5 py-3 rounded-xl bg-accent/90 backdrop-blur-md shadow-lg shadow-accent/20 border border-blue-400/30">
            <span class="inline-block text-sm font-medium text-white">
                <%= success %>
            </span>
        </div>
        <% } %>

<div class="w-full min-h-screen flex flex-col lg:flex-row px-6 md:px-12 lg:px-16 py-10 gap-10">

    <!-- Sidebar -->
    <div class="w-full lg:w-1/5">

        <div class="flex items-center gap-3 flex-wrap">
            <h3 class="text-xs font-semibold uppercase tracking-widest text-white/50">Sort by</h3>

            <form action="/shop">
                <select
                    class="bg-white/5 border border-white/10 text-sm px-3 py-2 rounded-lg outline-none focus:border-accent transition-colors duration-300"
                    name="sortby">

                    <option class="bg-noir" value="popular">Popular</option>
                    <option class="bg-noir" value="newest">Newest</option>

                </select>
            </form>
        </div>

        <div class="mt-12 flex flex-col gap-4">
            <a href="#" class="text-sm font-medium text-white/80 hover:text-accent transition-colors duration-300 w-fit">New Collection</a>
            <a href="#" class="text-sm font-medium text-white/80 hover:text-accent transition-colors duration-300 w-fit">All Products</a>
            <a href="#" class="text-sm font-medium text-white/80 hover:text-accent transition-colors duration-300 w-fit">Discounted Products</a>
        </div>

        <div class="w-full h-[1px] bg-white/10 my-10"></div>

        <div>
            <h3 class="text-xs font-semibold uppercase tracking-widest text-white/50 mb-4">Filter by :</h3>

            <div class="flex flex-col gap-4">
                <a href="#" class="text-sm font-medium text-white/80 hover:text-accent transition-colors duration-300 w-fit">Availability</a>
                <a href="#" class="text-sm font-medium text-white/80 hover:text-accent transition-colors duration-300 w-fit">Discount</a>
            </div>
        </div>

    </div>

    <!-- Products -->
    <div class="w-full lg:w-4/5">

        <div class="grid grid-cols-2 md:grid-cols-3 xl:grid-cols-4 gap-6">

            <% products.forEach(function(product){ %>

                <div class="group rounded-2xl overflow-hidden border border-white/5 shadow-xl hover:shadow-2xl hover:-translate-y-2 transition-all duration-300">

                    <!-- Product Image -->
                    <div
                        class="h-64 md:h-72 flex items-center justify-center overflow-hidden"
                        style="background-color:<%= product.bgcolor %>">

                        <img
                            src="data:image/jpeg;base64,<%= product.image.toString('base64') %>"
                            alt="<%= product.name %>"
                            class="max-h-[85%] max-w-[85%] object-contain group-hover:scale-110 transition-transform duration-500 ease-out">

                    </div>

                    <!-- Product Info -->
                    <div
                        class="flex items-center justify-between px-5 py-5"
                        style="background-color:<%= product.panelcolor %>; color:<%= product.textcolor %>">

                        <div>

                            <h3 class="text-base md:text-lg font-semibold leading-none tracking-tight">
                                <%= product.name %>
                            </h3>

                            <h4 class="mt-2.5 text-sm md:text-base font-medium opacity-80">
                                ₹ <%= product.price %>
                            </h4>

                        </div>

                        
                        <a href="/addtocart/<%= product._id %>" class="group/btn w-10 h-10 rounded-full bg-white flex items-center justify-center hover:scale-110 hover:bg-accent transition-all duration-300 shrink-0">

                            <i class="ri-add-line text-xl text-black group-hover/btn:text-white transition-colors duration-300"></i>

                        </a>

                    </div>

                </div>

            <% }) %>

        </div>

    </div>

</div>

<%- include('./partials/footer') %>
