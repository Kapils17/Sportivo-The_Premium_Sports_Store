<%- include('./partials/header') %>


<% if(success.length>0){ %>
        <div class="absolute top-5 left-1/2 -translate-x-1/2 -translate-y-1/2 p-3 rounded-md bg-blue-500">
            <span class="inline-block mt-1 mb-1 text-white">
                <%= success %>
            </span>
        </div>
        <% } %>

<div class="w-full min-h-screen flex px-16 py-10">

    <!-- Sidebar -->
    <div class="w-1/4 pr-12">

        <div class="flex items-center gap-3">
            <h3 class="text-lg">Sort by</h3>

            <form action="/shop">
                <select
                    class="border border-gray-300 px-3 py-2 rounded outline-none"
                    name="sortby">

                    <option value="popular">Popular</option>
                    <option value="newest">Newest</option>

                </select>
            </form>
        </div>

        <div class="mt-16 flex flex-col gap-3">
            <a href="#" class="hover:text-gray-500">New Collection</a>
            <a href="#" class="hover:text-gray-500">All Products</a>
            <a href="#" class="hover:text-gray-500">Discounted Products</a>
        </div>

        <div class="mt-20">
            <h3 class="font-medium mb-4">Filter by :</h3>

            <div class="flex flex-col gap-3">
                <a href="#" class="hover:text-gray-500">Availability</a>
                <a href="#" class="hover:text-gray-500">Discount</a>
            </div>
        </div>

    </div>

    <!-- Products -->
    <div class="w-3/4">

        <div class="grid grid-cols-4 gap-6">

            <% products.forEach(function(product){ %>

                <div class="w-64">

                    <!-- Product Image -->
                    <div
                        class="h-72 flex items-center justify-center overflow-hidden"
                        style="background-color:<%= product.bgcolor %>">

                        <img
                            src="data:image/jpeg;base64,<%= product.image.toString('base64') %>"
                            alt="<%= product.name %>"
                            class="max-h-[85%] max-w-[85%] object-contain">

                    </div>

                    <!-- Product Info -->
                    <div
                        class="flex items-center justify-between px-5 py-5"
                        style="background-color:<%= product.panelcolor %>; color:<%= product.textcolor %>">

                        <div>

                            <h3 class="text-xl font-medium leading-none">
                                <%= product.name %>
                            </h3>

                            <h4 class="mt-3 text-lg">
                                ₹ <%= product.price %>
                            </h4>

                        </div>

                        
                        <a href="/addtocart/<%= product._id %>" class="w-10 h-10 rounded-full bg-white flex items-center justify-center hover:scale-110 transition duration-300">

                            <i class="ri-add-line text-xl text-black"></i>

                        </a>

                    </div>

                </div>

            <% }) %>

        </div>

    </div>

</div>

<%- include('./partials/footer') %>