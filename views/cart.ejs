<%- include('./partials/header') %>

<% user.cart.forEach(function(item) { %>

<div class="w-full min-h-screen flex items-start px-20 py-20 gap-10">

    <!-- Product Card -->
    <div class="w-[30%] rounded-md overflow-hidden shadow-lg">

        <div
            class="w-full flex justify-center items-center h-80"
            style="background-color:<%= item.bgcolor %>;"
        >
            <img
                class="h-[18rem] object-contain"
                src="data:image/jpeg;base64,<%= item.image.toString('base64') %>"
                alt="<%= item.name %>"
            >
        </div>

        <div
            class="w-full flex justify-between px-5 py-4"
            style="background-color:<%= item.panelcolor %>;"
        >
            <h3 class="text-2xl font-semibold">
                <%= item.name %>
            </h3>

            <div class="flex items-center gap-2">
                <i class="w-7 h-7 bg-white rounded-full flex items-center justify-center ri-add-line cursor-pointer"></i>

                <div class="px-2 py-1 rounded-md bg-white text-black">
                    1
                </div>

                <i class="w-7 h-7 bg-white rounded-full flex items-center justify-center ri-subtract-line cursor-pointer"></i>
            </div>
        </div>

        <div
            class="flex items-center justify-between px-5 py-3"
            style="background-color:<%= item.textcolor %>;"
        >
            <h4 class="text-lg text-white">
                Net Total
            </h4>

            <h2 class="text-lg text-white font-semibold">
                ₹ <%= item.price - item.discount + 20 %>
            </h2>
        </div>

    </div>

    <!-- Price Breakdown -->
    <div class="w-[70%]">

        <h3 class="text-2xl font-semibold">
            Price Breakdown
        </h3>

        <div class="px-10 mt-5">

            <div class="flex mt-3">
                <h4 class="w-1/3">Total MRP</h4>
                <h4>₹ <%= item.price %></h4>
            </div>

            <div class="flex mt-3">
                <h4 class="w-1/3">Discount on MRP</h4>
                <h4>- ₹ <%= item.discount %></h4>
            </div>

            <div class="flex mt-3">
                <h4 class="w-1/3">Platform Fee</h4>
                <h4>₹ 20</h4>
            </div>

            <div class="flex mt-3">
                <h4 class="w-1/3">Shipping Fee</h4>
                <h4>FREE</h4>
            </div>

        </div>

        <div class="w-full h-[1px] bg-gray-300 mt-10"></div>

        <div class="flex mt-5">
            <h3 class="w-1/3 text-xl font-semibold">
                Total Amount
            </h3>

            <h3 class="text-xl font-bold text-green-600">
                ₹ <%= item.price - item.discount + 20 %>
            </h3>
        </div>

    </div>

</div>

<% }) %>

<%- include('./partials/footer') %>