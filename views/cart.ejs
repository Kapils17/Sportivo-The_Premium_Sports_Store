<%- include('./partials/header') %>

<% if(user.cart.length === 0) { %>

    <div class="w-full min-h-screen flex flex-col items-center justify-center px-6 text-center">
        <i class="ri-shopping-bag-4-line text-6xl text-white/15 mb-6"></i>
        <h3 class="font-display text-2xl md:text-3xl font-black uppercase tracking-tight text-white/80">Your bag is empty</h3>
        <p class="text-white/40 mt-3 max-w-sm">Looks like you haven't added anything yet. Explore the collection and find your gear.</p>
        <a href="/shop" class="mt-8 px-8 py-3.5 rounded-xl bg-accent text-white text-xs font-bold uppercase tracking-widest hover:bg-blue-500 hover:shadow-[0_0_25px_rgba(37,99,235,0.5)] hover:scale-105 active:scale-95 transition-all duration-300">
            Continue Shopping
        </a>
    </div>

<% } %>

<% user.cart.forEach(function(item) { %>

<div class="w-full min-h-screen flex flex-col lg:flex-row items-start px-6 md:px-12 lg:px-20 py-16 gap-10">

    <!-- Product Card -->
    <div class="w-full lg:w-[32%] rounded-2xl overflow-hidden shadow-2xl border border-white/5">

        <div
            class="w-full flex justify-center items-center h-72 md:h-80"
            style="background-color:<%= item.bgcolor %>;"
        >
            <img
                class="h-[16rem] md:h-[18rem] object-contain"
                src="data:image/jpeg;base64,<%= item.image.toString('base64') %>"
                alt="<%= item.name %>"
            >
        </div>

        <div
            class="w-full flex justify-between items-center px-5 py-4"
            style="background-color:<%= item.panelcolor %>;"
        >
            <h3 class="text-xl md:text-2xl font-semibold tracking-tight">
                <%= item.name %>
            </h3>

            <div class="flex items-center gap-2.5">
                <i class="w-7 h-7 bg-white rounded-full flex items-center justify-center ri-add-line cursor-pointer hover:bg-accent hover:text-white transition-colors duration-300 text-sm"></i>

                <div class="px-3 py-1 rounded-md bg-white text-black text-sm font-semibold">
                    1
                </div>

                <i class="w-7 h-7 bg-white rounded-full flex items-center justify-center ri-subtract-line cursor-pointer hover:bg-accent hover:text-white transition-colors duration-300 text-sm"></i>
            </div>
        </div>

        <div
            class="flex items-center justify-between px-5 py-4"
            style="background-color:<%= item.textcolor %>;"
        >
            <h4 class="text-sm md:text-base text-white/80 uppercase tracking-widest font-medium">
                Net Total
            </h4>

            <h2 class="text-lg md:text-xl text-white font-bold">
                ₹ <%= item.price - item.discount + 20 %>
            </h2>
        </div>

    </div>

    <!-- Price Breakdown -->
    <div class="w-full lg:w-[68%] bg-white/5 border border-white/10 rounded-2xl p-8 md:p-10 backdrop-blur-xl">

        <h3 class="font-display text-xl md:text-2xl font-black uppercase tracking-tight">
            Price Breakdown
        </h3>

        <div class="mt-8 space-y-4">

            <div class="flex justify-between items-center text-sm md:text-base text-white/70">
                <h4>Total MRP</h4>
                <h4 class="font-medium text-white">₹ <%= item.price %></h4>
            </div>

            <div class="flex justify-between items-center text-sm md:text-base text-white/70">
                <h4>Discount on MRP</h4>
                <h4 class="font-medium text-lime">- ₹ <%= item.discount %></h4>
            </div>

            <div class="flex justify-between items-center text-sm md:text-base text-white/70">
                <h4>Platform Fee</h4>
                <h4 class="font-medium text-white">₹ 20</h4>
            </div>

            <div class="flex justify-between items-center text-sm md:text-base text-white/70">
                <h4>Shipping Fee</h4>
                <h4 class="font-medium text-lime">FREE</h4>
            </div>

        </div>

        <div class="w-full h-[1px] bg-white/10 mt-8"></div>

        <div class="flex justify-between items-center mt-6">
            <h3 class="text-lg md:text-xl font-bold uppercase tracking-tight">
                Total Amount
            </h3>

            <h3 class="text-xl md:text-2xl font-black text-lime">
                ₹ <%= item.price - item.discount + 20 %>
            </h3>
        </div>

    </div>

</div>

<% }) %>

<%- include('./partials/footer') %>
