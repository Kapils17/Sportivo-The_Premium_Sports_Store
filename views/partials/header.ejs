<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sportivo | Premium Sportswear</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Archivo:wght@600;700;800;900&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        noir: '#0B0B0B',
                        panel: '#141414',
                        panel2: '#1A1A1A',
                        accent: '#2563EB',
                        lime: '#84CC16',
                    },
                    fontFamily: {
                        display: ['Archivo', 'Helvetica Now Display', 'sans-serif'],
                        body: ['Inter', 'Helvetica Now Display', 'sans-serif'],
                    },
                }
            }
        }
    </script>
    <style>
        html { scroll-behavior: smooth; }
        ::selection { background-color: #2563EB; color: #ffffff; }
    </style>
</head>

<body class="font-body bg-noir text-white antialiased">

    <nav class="fixed top-0 left-0 w-full z-50 backdrop-blur-xl bg-noir/70 border-b border-white/10">
        <div class="max-w-7xl mx-auto flex items-center justify-between px-6 md:px-10 py-4">

            <h3 class="font-display text-2xl md:text-3xl font-black uppercase tracking-tight text-white">
                sport<span class="text-accent">ivo</span>
            </h3>

            <% var loggedin = typeof loggedin !== "undefined" ? loggedin : true %>

            <% if(loggedin){ %>
                <div class="flex items-center gap-6 md:gap-8 text-xs md:text-sm font-semibold uppercase tracking-widest">

                    <a href="/shop" class="relative group text-white/80 hover:text-white transition-colors duration-300">
                        Shop
                        <span class="absolute -bottom-1 left-0 w-0 h-[1.5px] bg-accent group-hover:w-full transition-all duration-300"></span>
                    </a>

                    <a href="/cart" class="relative group text-white/80 hover:text-white transition-colors duration-300 flex items-center gap-1.5">
                        <i class="ri-shopping-cart-2-line text-base"></i>
                        <span class="hidden sm:inline">Cart</span>
                        <span class="absolute -bottom-1 left-0 w-0 h-[1.5px] bg-accent group-hover:w-full transition-all duration-300"></span>
                    </a>

                    <a href="" class="relative group text-white/80 hover:text-white transition-colors duration-300">
                        My account
                        <span class="absolute -bottom-1 left-0 w-0 h-[1.5px] bg-accent group-hover:w-full transition-all duration-300"></span>
                    </a>

                    <a class="text-red-500 hover:text-red-400 transition-colors duration-300" href="/user/logout">Logout</a>

                </div>
            <% } %>

        </div>
    </nav>
    <div class="h-[64px] md:h-[76px]"></div>
