<%- include('./partials/header') %>
    <div class="relative w-full min-h-screen overflow-hidden flex px-6 md:px-20">

        <div class="pointer-events-none absolute top-1/4 left-1/2 -translate-x-1/2 w-[500px] h-[500px] bg-accent/15 rounded-full blur-[130px]"></div>

        <div class="relative w-full flex items-center justify-center min-h-screen">
            <div class="w-full max-w-md bg-white/5 backdrop-blur-xl border border-white/10 rounded-3xl shadow-2xl p-8 md:p-10">

                <p class="text-xs font-semibold uppercase tracking-[0.2em] text-accent mb-3">Restricted Access</p>
                <h4 class="font-display text-3xl md:text-4xl font-black uppercase tracking-tight mb-8">
                    Admin Access
                </h4>

                <form action="/create" method="post" class="space-y-4">
                    <input class="block bg-white/5 w-full px-4 py-3 border border-white/10 rounded-xl text-sm placeholder-white/30 outline-none focus:border-accent focus:bg-white/10 transition-all duration-300"
                        type="email" placeholder="Email" name="email">
                    <input class="block bg-white/5 w-full px-4 py-3 border border-white/10 rounded-xl text-sm placeholder-white/30 outline-none focus:border-accent focus:bg-white/10 transition-all duration-300"
                        type="password" placeholder="Password" name="password">
                    <input class="w-full mt-2 px-5 py-3.5 rounded-xl bg-accent text-white text-xs font-bold uppercase tracking-widest cursor-pointer hover:bg-blue-500 hover:shadow-[0_0_25px_rgba(37,99,235,0.5)] hover:scale-[1.02] active:scale-[0.98] transition-all duration-300"
                        type="submit" value="Login">
                </form>

            </div>
        </div>

    </div>
    <%- include('./partials/footer') %>
